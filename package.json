{
  "name": "tournament-app",
  "version": "1.0.0",
  "description": "Sistema de gestión de torneos con doble eliminación",
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "build": "cd app && npm run build",
    "install:all": "cd backend && npm install && cd ../app && npm install"
  },
  "keywords": [
    "tournament",
    "bracket",
    "armwrestling",
    "sports"
  ],
  "private": true,
  "devDependencies": {
    "docx": "^9.6.0"
  }
}
