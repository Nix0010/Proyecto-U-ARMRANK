# ============================================
# CONFIGURACIÓN DE BASE DE DATOS (REQUERIDO)
# ============================================
# PostgreSQL connection string
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# 
# Para desarrollo local:
DATABASE_URL="postgresql://postgres:password@localhost:5432/tournament_db"
#
# Para producción (Ubuntu Server):
# DATABASE_URL="postgresql://tournament:tu_password_seguro@localhost:5432/tournament_db"
#
# Para Docker:
# DATABASE_URL="postgresql://tournament:tu_password_seguro@postgres:5432/tournament_db"

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# CONFIGURACIÓN CORS (SEGURIDAD)
# ============================================
# Dominio del frontend permitido
# En desarrollo:
FRONTEND_URL="http://localhost:5173"
#
# En producción:
# FRONTEND_URL="https://tu-dominio.com"
