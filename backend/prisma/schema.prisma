generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?  // null for OAuth users
  googleId     String?  @unique
  avatar       String?
  country      String?
  team         String?
  role         String   @default("organizer") // admin | organizer | athlete | spectator
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournaments  Tournament[]
  participants Participant[]

  @@map("users")
}

// ─── Tournament ───────────────────────────────────────────────────────────────

model Tournament {
  id                  String    @id @default(uuid())
  name                String
  description         String?
  type                String    @default("double_elimination") // single_elimination | double_elimination | round_robin | vendetta
  status              String    @default("draft") // draft | in_progress | completed | cancelled
  sport               String    @default("armwrestling")
  maxParticipants     Int       @default(16)
  currentParticipants Int       @default(0)
  location            String?
  organizerName       String?
  startDate           DateTime?
  endDate             DateTime?
  bestOf              Int       @default(1) // For vendetta: 1, 3, 5, 7
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Optional owner — tournaments can still exist without a user (backward compat)
  createdById  String?
  createdBy    User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  participants Participant[]
  matches      Match[]
  categories   Category[]

  @@map("tournaments")
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id           String   @id @default(uuid())
  name         String   // e.g. "-70kg Derecha"
  weightClass  String?  // e.g. "70" (kg)
  arm          String   @default("right") // "right" | "left" | "both"
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  participants Participant[]
  matches      Match[]

  @@map("categories")
}

// ─── Participant ──────────────────────────────────────────────────────────────

model Participant {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  avatar    String?
  seed      Int?
  team      String?
  country   String?
  weight    Float?   // Weight in kg
  status    String   @default("active") // active | eliminated | withdrawn
  createdAt DateTime @default(now())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Optional link to a registered user account
  userId  String?
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  stats ParticipantStats?

  @@map("participants")
}

// ─── Participant Stats ────────────────────────────────────────────────────────

model ParticipantStats {
  id            String @id @default(uuid())
  wins          Int    @default(0)
  losses        Int    @default(0)
  draws         Int    @default(0)
  pointsFor     Int    @default(0)
  pointsAgainst Int    @default(0)
  matchesPlayed Int    @default(0)
  rank          Int?

  participantId String      @unique
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("participant_stats")
}

// ─── Match ────────────────────────────────────────────────────────────────────

model Match {
  id             String   @id @default(uuid())
  round          Int
  position       Int
  bracket        String   // 'winners' | 'losers' | 'grand_final' | 'group' | 'vendetta'
  status         String   @default("pending") // pending | in_progress | completed | cancelled
  participant1Id String?
  participant2Id String?
  winnerId       String?
  loserId        String?
  score1         Float?
  score2         Float?
  // Armwrestling-specific result
  resultType     String?  // 'pin' | 'foul' | 'forfeit' | 'points' | 'default'
  arm            String?  // 'right' | 'left'
  // Vendetta series (JSON array of individual round results)
  seriesResults  String?  // JSON: [{score1, score2, winner, resultType}]
  bestOf         Int      @default(1) // 1, 3, 5, 7
  nextMatchId    String?
  nextMatchSlot  Int?
  loserMatchId   String?
  loserMatchSlot Int?

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("matches")
}
